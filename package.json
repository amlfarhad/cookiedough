{
  "name": "cookiedough",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cookiedough": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "audit:url": "tsx src/cli/index.ts audit --url https://example.com --out .cookiedough-runs/example --json",
    "self:audit:local": "node dist/src/cli/index.js audit --repo . --docker off --out .cookiedough-runs/self-local --json"
  },
  "dependencies": {
    "@playwright/test": "^1.45.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0",
    "get-port": "^7.1.0",
    "nanoid": "^5.0.7",
    "sanitize-html": "^2.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.10",
    "@types/sanitize-html": "^2.11.0",
    "eslint": "^9.6.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
